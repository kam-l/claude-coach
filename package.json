{
  "name": "@kam-l/claude-coach",
  "version": "3.2.0",
  "description": "Session-aware coaching for Claude Code — curated tips and live contextual advice",
  "bin": {
    "claude-coach": "scripts/apply-tips.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "node tests/test.js",
    "local-install": "node -e \"const{execSync:r}=require('child_process'),f=r('npm pack').toString().trim();r('npm i -g '+f,{stdio:'inherit'});require('fs').unlinkSync(f)\"",
    "local-uninstall": "npm uninstall -g @kam-l/claude-coach"
  },
  "author": {
    "name": "kam-l"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "spinner",
    "tips",
    "tooltips",
    "dx",
    "developer-experience"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kam-l/claude-coach.git"
  },
  "files": [
    "scripts/",
    "skills/",
    "hooks/",
    "references/",
    "tips.json",
    ".claude-plugin/"
  ]
}
